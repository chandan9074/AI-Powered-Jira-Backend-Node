{
  "compilerOptions": {
    /* Base Options: */
    "target": "ES2022",
    "module": "CommonJS",
    // "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,  /* Allow importing .ts files with extensions */
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,

    /* Strict Type-Checking Options: */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Directory Options: */
    "rootDir": "./src",      /* Where your TS files live */
    "outDir": "./dist",      /* Where the compiled JS files will go */

    /* REMOVE allowImportingTsExtensions entirely */
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}