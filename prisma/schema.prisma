// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client" // Changed from prisma-client-js
  output   = "../src/generated/prisma" // Explicit output path
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  accounts      Account[]
  ledProjects   Project[]           @relation("ProjectLead")
  projectMemberships  ProjectMembership[]

  @@index([email])
  @@index([roleId])
}

model Department {
  id          Int       @id @default(autoincrement())
  slug        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?
  
  projects    Project[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Project {
  id           String     @id @default(uuid())
  key          String     @unique @db.VarChar(10) // e.g., "ENG"
  name         String     @db.VarChar(100)
  description  String?
  
  // Relations
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  
  leadId       String
  lead         User       @relation("ProjectLead", fields: [leadId], references: [id])
  
  memberships  ProjectMembership[]
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@index([departmentId])
  @@index([leadId])
}

// Maps Users to Projects with specific Roles
model ProjectMembership {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  roleId    String   // Reusing our dynamic Role model from the Auth phase!
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  // A user can only have one membership record per project
  @@unique([userId, projectId]) 
  @@index([userId])
  @@index([projectId])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "Super Admin", "QA Engineer", "Custom Client"
  description String?      
  isSystem    Boolean      @default(false) // Protects core roles from being deleted by users
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  users       User[]
  permissions Permission[] // Implicit Many-to-Many relation with Permissions
  projectMemberships ProjectMembership[]
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique // e.g., "ticket:write", "ticket:delete", "user:invite"
  description String?
  createdAt   DateTime @default(now())

  // Relations
  roles       Role[]   // Implicit Many-to-Many relation with Roles
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String   // "credentials", "google", "github"
  providerAccountId String   // The user's ID in the external system (or email for credentials)
  passwordHash      String?  // Nullable because social logins won't have a password
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}
